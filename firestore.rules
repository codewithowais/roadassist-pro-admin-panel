rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only authenticated admin users can access most things
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // Vendors:
    //   - Admins can do anything.
    //   - The public can CREATE a self-registration doc, but only with
    //     trust-sensitive fields locked to safe defaults so applicants
    //     can't self-approve.
    //   - Public read/update/delete is forbidden.
    match /vendors/{id} {
      allow read, update, delete: if isAdmin();
      allow create: if
        request.resource.data.status == "pending"
        && request.resource.data.kyc == "pending"
        && request.resource.data.isVerified == false
        && request.resource.data.source == "self_registration"
        && request.resource.data.rating == 0
        && request.resource.data.reviewCount == 0
        // Light payload sanity: required string fields and size cap.
        && request.resource.data.businessName is string
        && request.resource.data.businessName.size() > 0
        && request.resource.data.businessName.size() < 200
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() > 0
        && request.resource.data.ownerName.size() < 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.phone.size() < 50;
    }

    match /users/{id} {
      allow read, write: if isAdmin();
    }
    match /service_requests/{id} {
      allow read, write: if isAdmin();
    }
    match /sos_hotspots/{id} {
      allow read, write: if isAdmin();
    }
    match /reviews/{id} {
      allow read, write: if isAdmin();
    }
    match /notifications/{id} {
      allow read, write: if isAdmin();
    }
    match /audit_log/{id} {
      allow read, write: if isAdmin();
    }
    match /app_config/{id} {
      allow read, write: if isAdmin();
    }

    // admin_users — self-read only (needed for the login guard check)
    // write is admin-only (to prevent self-escalation)
    match /admin_users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }
  }
}
