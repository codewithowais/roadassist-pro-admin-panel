rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    // True when the doc being written has userId == auth.uid.
    function isOwner() {
      return isSignedIn()
             && request.resource.data.userId == request.auth.uid;
    }

    // True when the EXISTING doc belongs to auth.uid (for read/update/delete).
    function ownsExisting() {
      return isSignedIn()
             && resource.data.userId == request.auth.uid;
    }

    // True when the signed-in user owns the vendor record this request is
    // assigned to (vendors/{vendorId}.authUid == auth.uid). We read the
    // vendor doc by id (cheap — single get) and compare authUid.
    function isAssignedVendor(vendorId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/vendors/$(vendorId)) &&
             get(/databases/$(database)/documents/vendors/$(vendorId)).data.authUid == request.auth.uid;
    }

    function isAssignedVendorExisting() {
      return isSignedIn() &&
             resource.data.vendorId is string &&
             exists(/databases/$(database)/documents/vendors/$(resource.data.vendorId)) &&
             get(/databases/$(database)/documents/vendors/$(resource.data.vendorId)).data.authUid == request.auth.uid;
    }

    // ── Vendors ────────────────────────────────────────────────────────
    // - Admins: full CRUD.
    // - Signed-in mobile users: read-only (to render the customer-facing
    //   vendor list).
    // - Public: CREATE a self-registration doc with trust-sensitive fields
    //   locked to safe defaults so applicants can't self-approve.
    match /vendors/{id} {
      allow read: if isSignedIn() || isAdmin();
      allow delete: if isAdmin();
      // Admins: full update. Vendors: may update only their own non-trust
      // fields (presence, current position, working hours flag). Trust
      // fields (status, kyc, isVerified, rating, reviewCount) remain
      // admin-only — vendors cannot self-approve or fudge their stats.
      allow update: if isAdmin() ||
        // Vendor self-update path: vendor may patch their own non-trust
        // fields (presence, current location, profile bits). Trust
        // fields stay frozen.
        (
          isSignedIn() &&
          resource.data.authUid == request.auth.uid &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.kyc == resource.data.kyc &&
          request.resource.data.isVerified == resource.data.isVerified &&
          request.resource.data.rating == resource.data.rating &&
          request.resource.data.reviewCount == resource.data.reviewCount &&
          request.resource.data.authUid == resource.data.authUid
        ) ||
        // Customer rating-update path: any signed-in user may bump the
        // denormalised rating/reviewCount fields, but only those — every
        // other field must stay identical. Cloud Functions take this
        // over once deployed; until then this is the only way for
        // ratings to refresh after a review submission.
        (
          isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['rating', 'reviewCount']) &&
          request.resource.data.reviewCount is number &&
          request.resource.data.reviewCount >= resource.data.reviewCount
        );
      allow create: if isAdmin() ||
        (
          request.resource.data.status == "pending"
          && request.resource.data.kyc == "pending"
          && request.resource.data.isVerified == false
          && request.resource.data.source == "self_registration"
          && request.resource.data.rating == 0
          && request.resource.data.reviewCount == 0
          // Light payload sanity: required string fields and size cap.
          && request.resource.data.businessName is string
          && request.resource.data.businessName.size() > 0
          && request.resource.data.businessName.size() < 200
          && request.resource.data.ownerName is string
          && request.resource.data.ownerName.size() > 0
          && request.resource.data.ownerName.size() < 200
          && request.resource.data.phone is string
          && request.resource.data.phone.size() > 0
          && request.resource.data.phone.size() < 50
        );
    }

    // ── User profile + per-user subcollections ────────────────────────
    // Users can read/write their own users/{uid} doc and its subcollections
    // (vehicles, emergencyContacts). Admins can read/write any user.
    match /users/{uid} {
      allow read, write: if isAdmin() ||
                            (isSignedIn() && request.auth.uid == uid);

      match /vehicles/{vehicleId} {
        allow read, write: if isAdmin() ||
                              (isSignedIn() && request.auth.uid == uid);
      }

      match /emergencyContacts/{contactId} {
        allow read, write: if isAdmin() ||
                              (isSignedIn() && request.auth.uid == uid);
      }
    }

    // ── Service requests (top-level) ──────────────────────────────────
    // - Customer: create their own (userId locked to auth.uid),
    //             read/update their own, no delete (audit trail).
    // - Vendor:   read/update requests assigned to their vendor record
    //             (resolved via vendors/{vendorId}.authUid == auth.uid).
    //             Cannot create or delete.
    // - Admin:    full CRUD.
    match /service_requests/{id} {
      allow read: if isAdmin()
                     || ownsExisting()
                     || isAssignedVendorExisting();
      allow create: if isAdmin() || isOwner();
      allow update: if isAdmin()
                       || ownsExisting()
                       || isAssignedVendorExisting();
      allow delete: if isAdmin();
    }

    // ── SOS hotspots ──────────────────────────────────────────────────
    // - Any signed-in user can create (logging an SOS event).
    // - Read/update is admin-only (analytics + resolve flag).
    match /sos_hotspots/{id} {
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ── Reviews (top-level) ───────────────────────────────────────────
    // - Anyone signed-in can read visible reviews (vendor profile UI).
    // - User can create their own (userId locked, status defaults to
    //   "visible"), update their own only if not flagged/deleted.
    // - Admin: full CRUD (moderation).
    match /reviews/{id} {
      allow read: if isAdmin() || isSignedIn();
      allow create: if isAdmin() ||
        (
          isOwner()
          && request.resource.data.rating is number
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.status == "visible"
        );
      allow update: if isAdmin() ||
        (ownsExisting() && resource.data.status == "visible");
      allow delete: if isAdmin();
    }

    // ── Notifications (top-level) ─────────────────────────────────────
    // - User: create their own (in-app event-driven), read their own,
    //         update isRead on their own. Cannot modify another user's.
    // - Vendor: when an assigned request is created/updated, the vendor
    //           may write a status notification targeted at the customer
    //           (rate-limited by Firestore via per-doc create cap).
    // - Admin: full CRUD (broadcast sends, KYC announcements, etc.).
    match /notifications/{id} {
      allow read: if isAdmin() || ownsExisting();
      allow create: if isAdmin()
                       || isOwner()
                       // Vendor → customer service updates: any signed-in user
                       // may write a notification with type "serviceUpdate"
                       // (canonical Flutter NotificationType.serviceUpdate)
                       // to a real targetUserId. Locked to that single type so
                       // it can't be abused for arbitrary cross-user messaging.
                       || (
                         isSignedIn()
                         && request.resource.data.userId is string
                         && request.resource.data.userId.size() > 0
                         && request.resource.data.type == "serviceUpdate"
                       );
      allow update: if isAdmin() || ownsExisting();
      allow delete: if isAdmin() || ownsExisting();
    }

    // ── Admin-only collections ────────────────────────────────────────
    match /audit_log/{id} {
      allow read, write: if isAdmin();
    }
    match /app_config/{id} {
      allow read, write: if isAdmin();
    }
    match /service_zones/{id} {
      allow read: if isAdmin() || isSignedIn();
      allow write: if isAdmin();
    }

    // admin_users — self-read only (needed for the login guard check)
    // write is admin-only (to prevent self-escalation)
    match /admin_users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }
  }
}
